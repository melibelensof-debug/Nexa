# ─── Base de datos (Supabase) ───────────────────────────────────────────────
# Obtené ambas URLs desde: Supabase → Settings → Database → Connection string
# DATABASE_URL  → "Transaction" pooler  (puerto 6543)
# DIRECT_URL    → "Session" mode / direct connection (puerto 5432)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="genera-un-secreto-largo-y-aleatorio"
NEXTAUTH_URL="https://tu-app.vercel.app"

# ─── Apify ───────────────────────────────────────────────────────────────────
APIFY_TOKEN=""
APIFY_GMAPS_ACTOR="compass/crawler-google-places"
APIFY_INSTAGRAM_ACTOR="apify/instagram-scraper"
APIFY_FACEBOOK_ACTOR="apify/facebook-pages-scraper"

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAILS="tu@email.com"

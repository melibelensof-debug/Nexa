# ─── Supabase ────────────────────────────────────────────────────────────────
# Settings → API en tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJh..."
# Service role: solo se usa en server. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY="eyJh..."

# ─── Apify ───────────────────────────────────────────────────────────────────
APIFY_TOKEN=""
APIFY_GMAPS_ACTOR="compass/crawler-google-places"
APIFY_INSTAGRAM_ACTOR="apify/instagram-scraper"
APIFY_FACEBOOK_ACTOR="apify/facebook-pages-scraper"

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAILS="tu@email.com"
